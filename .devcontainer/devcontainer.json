{
  "name": "Emotional OS + Darwin DevContainer",
  "image": "mcr.microsoft.com/devcontainers/universal:2-linux",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "src/streamlit_integration/chat_sandbox.py"
      ],
      "tasks": {
        "update-index": {
          "schedule": "0 0 */14 * *",
          "command": "bash .devcontainer/update_repo_index.sh"
        },
        "cleanup-root": {
          "schedule": "5 0 */14 * *",
          "command": "bash .devcontainer/cleanup_root.sh"
        }
      }
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "editor.formatOnSave": true,
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 1000
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "GitHub.copilot"
      ]
    }
  },
  // Set simple container environment variables instead of using a GHCR-hosted feature
  // The 'env-vars' feature required GHCR access and failed during Codespaces creation.
  "containerEnv": {
    "GLYPH_MODE": "hybrid",
    "DEFAULT_TONE": "plain"
  },
  "updateContentCommand": "/bin/bash .devcontainer/setup.sh",
  "postCreateCommand": "/bin/bash .devcontainer/post_create.sh && /bin/bash .devcontainer/update_repo_index.sh",
  // Disabled auto-start of Streamlit to prevent memory exhaustion
  // Run manually with: streamlit run src/streamlit_integration/chat_sandbox.py --server.enableCORS false --server.enableXsrfProtection false
  "portsAttributes": {
    "8501": {
      "label": "Emotional OS UI",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ]
}